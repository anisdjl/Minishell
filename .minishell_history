void	free_tokens(t_token **tokens)
{
	t_token	*tmp;

	tmp = (*tokens);
	if (!tokens || !(*tokens))
		return ;
	while (tmp->next)
	{
		if (tmp->value)
			free(tmp->value);
		tmp = tmp->next;
		(*tokens)->next = NULL;
		free((*tokens));
	}
	free(tmp->value);
	free(tmp);
	tokens = NULL;
}
